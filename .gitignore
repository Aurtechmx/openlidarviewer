# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules
.pnp
.pnp.*

# ── Build output ─────────────────────────────────────────────────────────────
dist
dist-ssr
build
vbuild
distcheck
coverage
*.tsbuildinfo

# ── Test / tooling output ────────────────────────────────────────────────────
test-results
playwright-report
playwright/.cache
# Vite / Vitest transient config transpiles (e.g. vitest.config.ts.timestamp-*.mjs)
*.timestamp-*.mjs

# ── Secrets & local environment — never publish these ───────────────────────
.env
.env.*
!.env.example
.npmrc
*.pem
*.key
*.p12
*.keystore
secrets.*
*.local

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── Generated archives & packaged deliverables ───────────────────────────────
# Keeps local deploy / package artifacts from drifting into a GitHub upload.
*.zip
*.tar
*.tar.gz
*.tgz
*.bundle

# ── Local scratch & verification scripts (not for publishing) ────────────────
_*.mjs
verify-*.mjs
trycheck*.mjs
*.tmp
_rmtest*

# ── Editor / OS ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
Thumbs.db
bundle-stats.html

# sandbox / editor artifacts — never commit
.fuse_hidden*
pw.sandbox.config.mjs

# local-only scratch
scratch/

# ── Private R&D artifacts — keep public/private separation airtight ──────────
# By convention these live OUTSIDE this published repo (in the parent project
# folder). Ignoring the naming patterns is defence-in-depth: even a stray copy
# dropped inside the repo can never be accidentally committed or shipped in the
# git-archive source zip. (Public RELEASE_NOTES_*.md are intentionally NOT here.)
_PRIVATE/
RESEARCH DOCUMENTS/
*WORKPLAN*.md
*WHITEPAPER*.md
*AUDIT*.md
TECH_EVALUATION*.md
QUALITYREVISION*.md
GITHUB_RELEASE_*.md
ELITE_*.md
# Large / classified sample clouds are private test data, not shipped fixtures
# (the tracked tiny.las / tiny.laz fixtures are bytes, not *.copc.laz).
*.copc.laz
*.copc.laz.*

# Serena project metadata (local tooling)
.serena/
.claude/

# Generated reproducibility artifacts (regenerate with npm run repro)
benchmarks/out/
