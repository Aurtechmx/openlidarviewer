{
  "name": "openlidarviewer",
  "version": "0.5.8",
  "description": "Open any 3D scan — drone LiDAR, terrestrial laser scan, or phone scan — instantly and privately, in a browser tab. No install, no upload, no conversion.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "lidar",
    "point-cloud",
    "las",
    "laz",
    "e57",
    "ply",
    "gltf",
    "viewer",
    "three.js",
    "webgpu"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:live": "tsc --noEmit && vite build --mode live",
    "package": "bash scripts/package.sh",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "node scripts/test-bucket.mjs unit",
    "test:export": "node scripts/test-bucket.mjs export",
    "test:terrain": "node scripts/test-bucket.mjs terrain",
    "test:ui": "node scripts/test-bucket.mjs ui",
    "test:slow": "node scripts/test-bucket.mjs slow",
    "test:buckets:verify": "node scripts/test-bucket.mjs --verify",
    "test:build": "npm run build && BUILD_CONTRACT=1 vitest run tests/chunkIsolation.test.ts tests/orbitSmoke.test.ts",
    "test:e2e": "playwright test",
    "repro": "REPRO=1 vitest run tests/reproPack.test.ts && python3 benchmarks/plots.py",
    "test:smoke": "playwright test tests/e2e/smoke.spec.ts tests/e2e/lazyChunkLoad.spec.ts",
    "test:smoke:live": "SMOKE_LIVE=1 playwright test tests/e2e/smoke.spec.ts tests/e2e/lazyChunkLoad.spec.ts",
    "test:release": "npm run typecheck && npm run lint:release-sync && npm run lint:main-deferral && npm run lint:inline-imports && npm run lint:unsafe-html && npm run lint:layer-boundaries && npm run lint:claim-register && npm run build:live && npm run check:bundle && npm run test:buckets:verify && npm run test:unit && npm run test:export && npm run test:terrain && npm run test:ui && npm run test:slow && npm run test:smoke:live",
    "lint:main-deferral": "node scripts/lint-main-deferral.mjs",
    "lint:inline-imports": "node scripts/lint-inline-imports.mjs",
    "lint:unsafe-html": "node scripts/lint-unsafe-html.mjs",
    "lint:layer-boundaries": "node scripts/lint-layer-boundaries.mjs",
    "lint:claim-register": "node scripts/lint-claim-register.mjs",
    "lint:release-sync": "node scripts/lint-release-sync.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "@loaders.gl/core": "^4.4.2",
    "@loaders.gl/gltf": "^4.4.2",
    "@loaders.gl/las": "^4.4.2",
    "@loaders.gl/obj": "^4.4.2",
    "@loaders.gl/ply": "^4.4.2",
    "@types/proj4": "^2.5.6",
    "laz-perf": "^0.0.7",
    "pdf-lib": "^1.17.1",
    "proj4": "^2.20.8",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/three": "^0.184.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "vitest": "^4.1.7"
  }
}
